<body>

<div class="birthday-card">
  <div class="card-header">
    <h1>🎂 Happy Birthday! 🎉</h1>
    <button class="confetti-btn" id="launchConfettiBtn">✨ Pop Confetti! ✨</button>
  </div>

  <!-- Digital Candle Section: interactive & blow-to-extinguish simulation -->
  <div class="candle-section">
    <div class="candle-title">🕯️ Make a Wish & Blow the Candle 🕯️</div>
    <div class="digital-candle" id="digitalCandleWrapper">
      <!-- Single digital candle with interactive flame -->
      <div class="candle-container" id="mainCandle">
        <div class="candle">
          <div class="flame lit" id="candleFlame"></div>
        </div>
        <div class="candle-label">✨ Birthday Wish Candle ✨</div>
      </div>
    </div>
    <div class="blow-hint" id="blowHint">💨 Click the flame to blow it out! (or click again to reignite) 💨</div>
    <div class="blow-hint" style="background: #f5e2c6; margin-top: 6px;">🎤 Bonus: Microphone blow detection (if allowed) — try blowing into your mic! 🎤</div>
  </div>

  <!-- Personalized Message Section with decorative fonts -->
  <div class="message-section">
    <div class="message-label">
      ✍️ Your Personalized Message
    </div>
    <div class="message-input-area">
      <input type="text" id="birthdayMessageInput" placeholder="e.g., Wishing you endless joy, laughter & cake! 🎂🎈" value="Happy Birthday to the most amazing person! May your day sparkle ✨">
    </div>
    <div class="decorative-message" id="decorativeMessageCard">
      <p id="dynamicMessageText">Happy Birthday to the most amazing person! May your day sparkle ✨</p>
      <span>❤️ with love & confetti ❤️</span>
    </div>
  </div>
  <div class="footer-note">
    🎈 Click anywhere on the card for extra mini‑confetti! 🎈
  </div>
</div>

<script>
  (function() {
    // ---------- CONFETTI LAUNCH (on load, plus manual trigger) ----------
    function launchConfetti(origin = 'center', intensity = 'medium') {
      // basic burst with variation
      let count = 150;
      let spread = 70;
      let startVelocity = 20;
      if (intensity === 'high') {
        count = 300;
        spread = 100;
        startVelocity = 25;
      } else if (intensity === 'low') {
        count = 80;
        spread = 50;
      }
      canvasConfetti({
        particleCount: count,
        spread: spread,
        origin: { y: 0.6 },
        startVelocity: startVelocity,
        colors: ['#ff0044', '#ffcc00', '#33ff66', '#ff66cc', '#44aaff', '#ffaa33'],
        decay: 0.9,
        ticks: 200
      });
      // additional side cascade
      setTimeout(() => {
        canvasConfetti({
          particleCount: 40,
          angle: 60,
          spread: 45,
          origin: { x: 0, y: 0.7 },
          colors: ['#ffaa88', '#ffdd88', '#ff8888']
        });
        canvasConfetti({
          particleCount: 40,
          angle: 120,
          spread: 45,
          origin: { x: 1, y: 0.7 },
          colors: ['#ffaa88', '#ffdd88', '#ff8888']
        });
      }, 120);
    }

    // on page load: burst of confetti to celebrate launch!
    window.addEventListener('load', () => {
      launchConfetti('center', 'high');
      // Also small initial greeting
    });

    // manual button confetti
    const confettiBtn = document.getElementById('launchConfettiBtn');
    confettiBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      launchConfetti('center', 'high');
      // also animate little feedback on button
      confettiBtn.style.transform = 'scale(0.97)';
      setTimeout(() => { confettiBtn.style.transform = ''; }, 100);
    });

    // extra: click on card background (but not interfering with inputs) sends mini confetti
    const card = document.querySelector('.birthday-card');
    card.addEventListener('click', (e) => {
      // avoid double triggers from inner buttons (they stopPropagation where needed)
      if (e.target.closest('.confetti-btn')) return;
      if (e.target.closest('#birthdayMessageInput')) return;
      if (e.target.closest('.candle-container')) return;
      launchConfetti('center', 'low');
    });

    // ---------- DIGITAL CANDLE LOGIC (toggle flame & blow detection) ----------
    const flameElement = document.getElementById('candleFlame');
    let isLit = true;   // starts lit

    function updateFlameState(lit) {
      isLit = lit;
      if (isLit) {
        flameElement.classList.remove('unlit');
        flameElement.classList.add('lit');
        flameElement.style.background = ''; // ensure radial override via class
        // Extra glow effect
        flameElement.style.boxShadow = '0 0 12px 3px #ffa500';
      } else {
        flameElement.classList.remove('lit');
        flameElement.classList.add('unlit');
        flameElement.style.boxShadow = 'none';
      }
      // optional: add small confetti burst when candle blown out or reignited? not needed but fun: small spark on reignite
      if (isLit) {
        canvasConfetti({
          particleCount: 12,
          spread: 18,
          origin: { y: 0.55, x: 0.5 },
          startVelocity: 8,
          colors: ['#ffaa33', '#ffdd77']
        });
      } else {
        // when blown out, little "poof" effect
        canvasConfetti({
          particleCount: 6,
          spread: 30,
          origin: { y: 0.55, x: 0.5 },
          startVelocity: 4,
          colors: ['#aaaaaa', '#cccc99'],
          gravity: 0.6
        });
      }
    }

    // Toggle by clicking on the candle or its flame or container
    const candleContainer = document.getElementById('mainCandle');
    const toggleCandle = () => {
      updateFlameState(!isLit);
    };
    candleContainer.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleCandle();
    });

    // ---------- BLOW DETECTION USING MICROPHONE (optional, with permission) ----------
    let mediaStream = null;
    let audioContext = null;
    let sourceNode = null;
    let analyserNode = null;
    let blowDetectionActive = false;
    let blowTriggerCooldown = false;

    // Function to request mic & setup blow detection
    async function initBlowDetection() {
      if (blowDetectionActive) return;
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
        mediaStream = stream;
        if (!audioContext) {
          audioContext = new (window.AudioContext || window.webkitAudioContext)();
        }
        if (sourceNode) sourceNode.disconnect();
        sourceNode = audioContext.createMediaStreamSource(stream);
        analyserNode = audioContext.createAnalyser();
        analyserNode.fftSize = 256;
        sourceNode.connect(analyserNode);
        const bufferLength = analyserNode.frequencyBinCount;
        const dataArray = new Uint8Array(bufferLength);
        
        function detectBlow() {
          if (!analyserNode || !blowDetectionActive) return;
          analyserNode.getByteTimeDomainData(dataArray);
          let maxSample = 0;
          for (let i = 0; i < bufferLength; i++) {
            let v = (dataArray[i] - 128) / 128;
            let amp = Math.abs(v);
            if (amp > maxSample) maxSample = amp;
          }
          const volume = maxSample;
          // threshold for "blow" - sensitivity tuned
          if (volume > 0.38 && isLit && !blowTriggerCooldown) {
            blowTriggerCooldown = true;
            // blow out candle!
            if (isLit) {
              updateFlameState(false);
              canvasConfetti({
                particleCount: 70,
                spread: 55,
                origin: { y: 0.55, x: 0.5 },
                startVelocity: 14,
                colors: ['#b0c4de', '#ffe0b5', '#f0e68c', '#ffdab9']
              });
              const hintDiv = document.getElementById('blowHint');
              const originalHTML = hintDiv.innerHTML;
              hintDiv.innerHTML = '💨✨ Whoosh! You blew out the candle! Make a wish! 🎂✨💨';
              setTimeout(() => {
                if (hintDiv && hintDiv.innerHTML.includes('Whoosh')) hintDiv.innerHTML = originalHTML;
              }, 2500);
            }
            setTimeout(() => { blowTriggerCooldown = false; }, 800);
          }
          requestAnimationFrame(detectBlow);
        }
        
        if (audioContext.state === 'suspended') {
          await audioContext.resume();
        }
        blowDetectionActive = true;
        detectBlow();
        const micHint = document.getElementById('blowHint');
        if (micHint && !micHint.innerHTML.includes('🎙️')) {
          micHint.innerHTML = '🎙️ Mic active! Blow into mic to extinguish! 🔥➡️💨 ' + micHint.innerHTML;
        }
      } catch (err) {
        console.warn("Microphone access not granted or error:", err);
        const micHint = document.getElementById('blowHint');
        if (micHint && !micHint.innerHTML.includes('Mic unavailable')) {
          micHint.innerHTML = '💨 Click flame to blow! (Mic unavailable: permission or no mic) 💨';
        }
      }
    }

    // Ask for mic permission on first user gesture (click on candle or blow hint)
    let micInitialized = false;
    function tryEnableMicBlow() {
      if (micInitialized) return;
      micInitialized = true;
      initBlowDetection().catch(e => console.log);
    }
    // Attach mic activation to candle and blow-hint with 'once' limited but also allow reattempt if failed
    candleContainer.addEventListener('click', () => tryEnableMicBlow(), { once: true });
    const blowHintElement = document.getElementById('blowHint');
    blowHintElement.addEventListener('click', () => tryEnableMicBlow(), { once: true });
    // also if user clicks anywhere on card gently try once, but not on confetti button
    card.addEventListener('click', function micOnce(e) {
      if (!micInitialized && !e.target.closest('.confetti-btn') && !e.target.closest('#birthdayMessageInput')) {
        tryEnableMicBlow();
        card.removeEventListener('click', micOnce);
      }
    }, { once: true });

    // clean up on page unload (optional)
    window.addEventListener('beforeunload', () => {
      if (mediaStream) {
        mediaStream.getTracks().forEach(track => track.stop());
      }
      if (audioContext) {
        audioContext.close();
      }
    });

    // ---------- PERSONALIZED MESSAGE SECTION (real-time update) ----------
    const messageInput = document.getElementById('birthdayMessageInput');
    const dynamicMsgElem = document.getElementById('dynamicMessageText');
    
    function updatePersonalizedMessage() {
      let rawText = messageInput.value.trim();
      if (rawText === "") {
        rawText = "🎈 Happy Birthday! Enjoy your special day! 🎈";
      }
      dynamicMsgElem.innerText = rawText;
      // small decorative bouncy effect on message card
      const msgCard = document.getElementById('decorativeMessageCard');
      msgCard.style.transform = 'scale(1.01)';
      setTimeout(() => { msgCard.style.transform = ''; }, 150);
    }
    
    messageInput.addEventListener('input', updatePersonalizedMessage);
    updatePersonalizedMessage(); // initial sync
    
    // Extra flair: when you type, tiny confetti pop for fun (optional)
    messageInput.addEventListener('keyup', (e) => {
      if (Math.random() < 0.2) {
        canvasConfetti({
          particleCount: 5,
          spread: 15,
          origin: { y: 0.85, x: 0.5 },
          startVelocity: 5,
          colors: ['#ffd966', '#ff9966']
        });
      }
    });
    
    // Also initial flame set lit (already lit by default)
    // Ensure that after blow detection user can manually reignite by clicking the candle.
    // Additional interactive: extra heavy confetti for main button
    function extraHeavyConfetti() {
      canvasConfetti({
        particleCount: 280,
        spread: 120,
        origin: { y: 0.5 },
        startVelocity: 20,
        colors: ['#ff66aa', '#ffcc44', '#66ffcc', '#ff8866', '#ffaa77']
      });
      setTimeout(() => {
        canvasConfetti({
          particleCount: 80,
          angle: 90,
          spread: 70,
          origin: { y: 0.4, x: 0.5 },
          startVelocity: 18,
        });
      }, 80);
    }
    confettiBtn.addEventListener('click', () => extraHeavyConfetti());
    
    // final subtle floating effect
    const style = document.createElement('style');
    style.textContent = `
      .flame.lit {
        animation: flicker 0.12s infinite alternate;
      }
      .decorative-message p {
        transition: all 0.2s;
      }
      .candle-container:active .candle {
        transform: translateY(2px);
      }
    `;
    document.head.appendChild(style);
    
    // Bonus: Simulate "wish" when candle blown out via microphone: we already show message
    // Additional small interactive: if candle is unlit and user blows into mic while unlit? we can also relight? optional but nice: blow to relight? no, but user can click.
    // For accessibility we also ensure that blow detection won't double-trigger repeatedly
    console.log("Happy Birthday Card ready! 🎉");
    
    // Extra feature: add a gentle floating animation for the flame when lit
    // Already done via flicker.
  })();
</script>
</body>
</html>
